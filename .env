# =============================================
# .env.example - Ghana Prison Service API
# =============================================
# Copy this file to .env and replace every <placeholder> value.
# Never commit the real .env file to Git.

# ==================== DEPLOYMENT ====================
PYTHON_VERSION=3.12.8

# ==================== APPLICATION ====================
APP_NAME=prison management system
APP_VERSION=v1.0.0
APP_ENV=<development|staging|production>
DEBUG=false
API_PREFIX=/api/v1
DOCS_ENABLED=false

HOST=0.0.0.0
PORT=8000
WORKERS=1

# ==================== CORS / HOST SECURITY ====================
ALLOWED_ORIGINS=<frontend-origin-1>,<frontend-origin-2>
ALLOWED_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
ALLOWED_HEADERS=*
ALLOW_CREDENTIALS=true
TRUSTED_HOSTS=localhost,127.0.0.1,0.0.0.0,<api-domain>,*.onrender.com

# ==================== DATABASE (MYSQL) ====================
MYSQL_DRIVER=mysql+mysqlconnector
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=@LocalHost2020
MYSQL_DATABASE=pms_db
DATABASE_URL=mysql+mysqlconnector://root:%40LocalHost2020@127.0.0.1:3306/pms_db
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800
DB_ECHO=false
STARTUP_SCHEMA_VALIDATION_TIMEOUT_SECONDS=5

# ==================== AUTHENTICATION / JWT ====================
SECRET_KEY=<generate-with-python-secrets-token-urlsafe>
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
BCRYPT_ROUNDS=12
PASSWORD_MIN_LENGTH=8
PASSWORD_MAX_LENGTH=128
PASSWORD_REQUIRE_SPECIAL=false
COMPROMISED_PASSWORDS=<comma-separated-disallowed-passwords>
MAX_ACTIVE_SESSIONS=5

# ==================== SUPER ADMIN SEED ====================
SUPERADMIN_EMAIL=<superadmin-email>
SUPERADMIN_PASSWORD=<superadmin-password>
SUPERADMIN_FIRST_NAME=<superadmin-first-name>
SUPERADMIN_LAST_NAME=<superadmin-last-name>

# ==================== TOKEN / REWARD SYSTEM ====================
TOKEN_VALUE_GHS=1.0
TOKEN_MIN_REDEMPTION_GHS=50.0
REFERRAL_BONUS_TOKENS=50
PURCHASE_REWARD_PERCENT=3.0

# ==================== EMAIL ====================
MAIL_PROVIDER=<smtp|sendgrid>
MAIL_FROM=<sender-email>
MAIL_FROM_NAME=<sender-name>
SMTP_HOST=<smtp-host>
SMTP_PORT=587
SMTP_USER=<smtp-username>
SMTP_PASSWORD=<smtp-password>
SMTP_TLS=true
SMTP_SSL=false
EMAIL_RETRY_ATTEMPTS=3
EMAIL_RETRY_DELAY_SECONDS=0.25

# ==================== SMS ====================
SMS_PROVIDER=<termii|twilio|vonage>
TERMII_API_KEY=<termii-api-key>
TERMII_FROM=<termii-sender-id>
TERMII_SMS_URL=<termii-sms-url>
SMS_MESSAGE_TYPE=plain
SMS_CHANNEL=generic
SMS_RETRY_ATTEMPTS=3
SMS_RETRY_DELAY_SECONDS=0.25
OUTBOUND_HTTP_TIMEOUT_SECONDS=10

# ==================== FILE STORAGE ====================
STORAGE_PROVIDER=<local|cloudinary|s3>
LOCAL_UPLOAD_DIR=<upload-directory>
MAX_UPLOAD_SIZE_MB=10
UPLOAD_CHUNK_SIZE_BYTES=1048576
ALLOWED_IMAGE_TYPES=image/jpeg,image/png,image/webp
ALLOWED_DOC_TYPES=application/pdf,image/jpeg,image/png

# ==================== RATE LIMITING ====================
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60
AUTH_RATE_LIMIT_REQUESTS=10
AUTH_RATE_LIMIT_WINDOW_SECONDS=60

# ==================== LOGGING / MAINTENANCE ====================
LOG_LEVEL=INFO
MAINTENANCE_MODE=false
MAINTENANCE_MESSAGE=<maintenance-message>
MAINTENANCE_BYPASS_IPS=127.0.0.1,localhost

# ==================== PAGINATION / EXPORTS ====================
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100
CSV_FILENAME_PREFIX=<csv-filename-prefix>
CSV_TIMESTAMP_FORMAT=%Y%m%d_%H%M%S

# ==================== BACKGROUND JOBS ====================
BACKGROUND_SCHEDULER_ENABLED=false
BACKGROUND_SCHEDULER_TIMEZONE=UTC
BACKGROUND_JOB_MAX_ATTEMPTS=3
BACKGROUND_JOB_RETRY_DELAY_SECONDS=5
PROMOTION_EXPIRY_JOB_MINUTES=60
REDIS_HEALTH_JOB_MINUTES=5
VENDOR_REFERRAL_EXPIRY_JOB_MINUTES=60
VENDOR_REFERRAL_INACTIVITY_JOB_MINUTES=60
VENDOR_REFERRAL_RESUME_JOB_MINUTES=60
VENDOR_REFERRAL_CAP_JOB_MINUTES=1440
REFERRAL_FRAUD_SCAN_JOB_MINUTES=60
REFERRAL_PAYOUT_RECONCILIATION_JOB_MINUTES=60
REFERRAL_REWARD_RECALCULATION_JOB_MINUTES=60
REFERRAL_REVERSAL_RECONCILIATION_JOB_MINUTES=60
REFERRAL_ANALYTICS_AGGREGATION_JOB_MINUTES=1440

