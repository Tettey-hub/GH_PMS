# =============================================
# .env.example - Ghana Prison Service API
# =============================================
# Copy this file to .env and replace every placeholder value.
# Never commit the real .env file to Git.

# ==================== DEPLOYMENT ====================
PYTHON_VERSION=3.12.8

# ==================== APPLICATION ====================
APP_NAME=Prison Management System
APP_VERSION=v1.0.0
APP_ENV=development
DEBUG=false
API_PREFIX=/api/v1
DOCS_ENABLED=false

HOST=0.0.0.0
PORT=8000
WORKERS=1

# ==================== CORS / HOST SECURITY ====================
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
ALLOWED_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
ALLOWED_HEADERS=*
ALLOW_CREDENTIALS=true
TRUSTED_HOSTS=localhost,127.0.0.1,0.0.0.0

# ==================== DATABASE (MYSQL) ====================
MYSQL_DRIVER=mysql+mysqlconnector
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=pms_user
MYSQL_PASSWORD=change-me
MYSQL_DATABASE=pms_db
DATABASE_URL=mysql+mysqlconnector://pms_user:change-me@127.0.0.1:3306/pms_db
DB_POOL_SIZE=20
STARTUP_SCHEMA_VALIDATION_TIMEOUT_SECONDS=5

# ==================== AUTHENTICATION / JWT ====================
SECRET_KEY=change-me-generate-with-python-secrets-token-urlsafe
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
BCRYPT_ROUNDS=12
PASSWORD_MIN_LENGTH=8
PASSWORD_MAX_LENGTH=128
PASSWORD_REQUIRE_SPECIAL=false
COMPROMISED_PASSWORDS=
MAX_ACTIVE_SESSIONS=5

# ==================== SUPER ADMIN SEED ====================
SUPERADMIN_EMAIL=admin@example.com
SUPERADMIN_PASSWORD=change-me
SUPERADMIN_FIRST_NAME=System
SUPERADMIN_LAST_NAME=Administrator

# ==================== EMAIL ====================
MAIL_PROVIDER=smtp
MAIL_FROM=no-reply@example.com
MAIL_FROM_NAME=Prison Management System
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=smtp-user
SMTP_PASSWORD=change-me
SMTP_TLS=true
SMTP_SSL=false
EMAIL_RETRY_ATTEMPTS=3
EMAIL_RETRY_DELAY_SECONDS=0.25

# ==================== SMS ====================
SMS_PROVIDER=termii
TERMII_API_KEY=change-me
TERMII_FROM=PMS
TERMII_SMS_URL=https://api.example.com/sms
SMS_MESSAGE_TYPE=plain
SMS_CHANNEL=generic
SMS_RETRY_ATTEMPTS=3
SMS_RETRY_DELAY_SECONDS=0.25
OUTBOUND_HTTP_TIMEOUT_SECONDS=10

# ==================== FILE STORAGE ====================
STORAGE_PROVIDER=local
LOCAL_UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE_MB=10
UPLOAD_CHUNK_SIZE_BYTES=1048576
ALLOWED_IMAGE_TYPES=image/jpeg,image/png,image/webp
ALLOWED_DOC_TYPES=application/pdf,image/jpeg,image/png

# ==================== RATE LIMITING ====================
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60
AUTH_RATE_LIMIT_REQUESTS=10
AUTH_RATE_LIMIT_WINDOW_SECONDS=60

# ==================== LOGGING / MAINTENANCE ====================
LOG_LEVEL=INFO
MAINTENANCE_MODE=false
MAINTENANCE_MESSAGE=
MAINTENANCE_BYPASS_IPS=127.0.0.1,localhost

# ==================== PAGINATION / EXPORTS ====================
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100
CSV_FILENAME_PREFIX=pms_export
CSV_TIMESTAMP_FORMAT=%Y%m%d_%H%M%S

# ==================== BACKGROUND JOBS ====================
BACKGROUND_SCHEDULER_ENABLED=false
BACKGROUND_SCHEDULER_TIMEZONE=UTC
BACKGROUND_JOB_MAX_ATTEMPTS=3
BACKGROUND_JOB_RETRY_DELAY_SECONDS=5
